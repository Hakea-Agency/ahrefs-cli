# ---------------------------------------------------------------------------
# Argument parsing
# ---------------------------------------------------------------------------

def main():
    parser = argparse.ArgumentParser(
        prog="ahrefs",
        description="Ahrefs SEO Analytics CLI — domain analysis, keyword research, backlinks, and SERP data via Ahrefs REST API v3.",
    )
    sub = parser.add_subparsers(dest="command")

    def add_common(p, target=True, keyword=False, keywords=False):
        if target:
            p.add_argument("target", help="Domain or URL to analyze")
        if keyword:
            p.add_argument("keyword", help="Keyword to research")
        if keywords:
            p.add_argument("keywords", nargs="+", help="Keywords to research")
        p.add_argument("--country", default="us", help="Country code (default: us)")
        p.add_argument("--date", help="Date YYYY-MM-DD (default: today)")
        p.add_argument("--date-from", help="Start date for history commands")
        p.add_argument("--limit", type=int, default=10, help="Max results (default: 10)")
        p.add_argument("--mode", default="subdomains",
                       choices=["domain", "subdomains", "prefix", "exact"],
                       help="Analysis mode (default: subdomains)")
        p.add_argument("--select", help="Comma-separated fields to return (overrides defaults)")
        p.add_argument("--where", help="Filter expression (e.g. 'domain_rating>30')")
        p.add_argument("--order-by", help="Sort field (prefix with - for desc, e.g. '-traffic')")
        p.add_argument("--json", action="store_true", help="Raw JSON output")
        p.add_argument("--format", choices=["table", "csv", "json"], default="table",
                       help="Output format (default: table)")
        p.add_argument("--protocol", choices=["both", "http", "https"], default="both",
                       help="Protocol filter (default: both)")
        return p

    # Site Explorer
    add_common(sub.add_parser("dr", help="Domain Rating"))
    add_common(sub.add_parser("backlinks", help="Backlink statistics"))
    add_common(sub.add_parser("backlinks-list", help="List all backlinks"))
    add_common(sub.add_parser("refdomains", help="Referring domains"))
    add_common(sub.add_parser("anchors", help="Anchor texts"))
    add_common(sub.add_parser("outlinks", help="Outgoing link stats"))
    add_common(sub.add_parser("metrics", help="All site metrics"))
    add_common(sub.add_parser("organic", help="Organic keywords"))
    add_common(sub.add_parser("top-pages", help="Top pages by traffic"))
    add_common(sub.add_parser("competitors", help="Organic competitors"))
    add_common(sub.add_parser("dr-history", help="Domain Rating history"))
    add_common(sub.add_parser("metrics-history", help="Metrics history"))
    add_common(sub.add_parser("pages-by-traffic", help="Pages ranked by organic traffic"))

    # Keywords Explorer
    add_common(sub.add_parser("keyword", help="Keyword overview"), target=False, keywords=True)
    add_common(sub.add_parser("volume-history", help="Search volume history"), target=False, keywords=True)
    add_common(sub.add_parser("matching", help="Matching keyword terms"), target=False, keyword=True)
    add_common(sub.add_parser("related", help="Related keyword terms"), target=False, keyword=True)
    add_common(sub.add_parser("suggestions", help="Search suggestions"), target=False, keyword=True)

    # SERP
    add_common(sub.add_parser("serp", help="SERP overview (top 100)"), target=False, keyword=True)

    # Batch
    p = sub.add_parser("batch", help="Batch domain analysis")
    p.add_argument("targets", nargs="+", help="Domains to analyze")
    p.add_argument("--json", action="store_true")
    p.add_argument("--format", choices=["table", "csv", "json"], default="table")

    # Usage
    sub.add_parser("usage", help="Show API usage this month")

    args = parser.parse_args()

    if not args.command:
        parser.print_help()
        sys.exit(0)

    api_key = get_api_key() if args.command != "usage" else ""

    commands = {
        "dr": cmd_dr,
        "backlinks": cmd_backlinks,
        "backlinks-list": cmd_backlinks_list,
        "refdomains": cmd_refdomains,
        "anchors": cmd_anchors,
        "outlinks": cmd_outlinks,
        "metrics": cmd_metrics,
        "organic": cmd_organic,
        "top-pages": cmd_top_pages,
        "competitors": cmd_competitors,
        "dr-history": cmd_dr_history,
        "metrics-history": cmd_metrics_history,
        "pages-by-traffic": cmd_pages_by_traffic,
        "keyword": cmd_keyword,
        "volume-history": cmd_volume_history,
        "matching": cmd_matching,
        "related": cmd_related,
        "suggestions": cmd_suggestions,
        "serp": cmd_serp,
        "batch": cmd_batch,
        "usage": cmd_usage,
    }

    fn = commands.get(args.command)
    if fn:
        fn(args, api_key)
    else:
        parser.print_help()


if __name__ == "__main__":
    main()
